# Copy to .env and fill in values. Never commit .env.

# EasyScore API (baseball stats & scores)
# Get from: easyscore.com
EASYSCORE_API_KEY=
EASYSCORE_TEAM_ID=13054
EASYSCORE_LEAGUE_ID=10144

# OneSignal (push notifications)
# Get from: onesignal.com → your app settings
# App ID is public — hardcoded in code
# ONESIGNAL_APP_ID=d367a901-afe3-4035-9417-794e6e80fcd4
ONESIGNAL_REST_API_KEY=
ONESIGNAL_API_KEY=

# Instagram
# Get from: Meta Developer Portal → Basic Display
INSTAGRAM_TOKEN=
INSTAGRAM_HANDLE=barracudas_nlb

# Anthropic Claude API (auto-generate game recaps)
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

